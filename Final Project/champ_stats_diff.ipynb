   "source": [
    "# Welch's t-test (Welch’s t-test shows that this difference is statistically significant.)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 91,
   "id": "da10bf1b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Welch's t-test\n",
      "t-statistic: 3.028645161515365\n",
      "p-value: 0.001695117499916816\n"
     ]
    }
   ],
   "source": [
    "# Welch's two sample t-test\n",
    "welch_result = stats.ttest_ind(\n",
    "    point_diff_champ,\n",
    "    point_diff_non_champ,\n",
    "    equal_var=False,\n",
    "    alternative=\"greater\"\n",
    ")\n",
    "\n",
    "print(\"Welch's t-test\")\n",
    "print(\"t-statistic:\", welch_result.statistic)\n",
    "print(\"p-value:\", welch_result.pvalue)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6550ca37",
   "metadata": {},
   "source": [
    "# Pooled t-test (Pooled t-test also show significance difference)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 92,
   "id": "53254005",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Pooled two sample t-test\n",
      "t-statistic: 2.9978194144283985\n",
      "p-value: 0.0015635189084324693\n"
     ]
    }
   ],
   "source": [
    "# Pooled two sample t-test\n",
    "pooled_result = stats.ttest_ind(\n",
    "    point_diff_champ,\n",
    "    point_diff_non_champ,\n",
    "    equal_var=True,\n",
    "    alternative=\"greater\"\n",
    ")\n",
    "\n",
    "print(\"Pooled two sample t-test\")\n",
    "print(\"t-statistic:\", pooled_result.statistic)\n",
    "print(\"p-value:\", pooled_result.pvalue)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6b02c528",
   "metadata": {},
   "source": [
    "# two sample Z-test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 93,
   "id": "6618b2c1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Large-sample z-test approximation\n",
      "z-statistic: 3.028645161515365\n",
      "p-value: 0.0012282651410662204\n"
     ]
    }
   ],
   "source": [
    "mean_champ = point_diff_champ.mean()\n",
    "mean_non_champ = point_diff_non_champ.mean()\n",
    "\n",
    "s_champ = point_diff_champ.std(ddof=1)\n",
    "s_non_champ = point_diff_non_champ.std(ddof=1)\n",
    "\n",
    "n_champ = len(point_diff_champ)\n",
    "n_non_champ = len(point_diff_non_champ)\n",
    "\n",
    "z_stat = (mean_champ - mean_non_champ) / np.sqrt(\n",
    "    s_champ**2 / n_champ + s_non_champ**2 / n_non_champ\n",
    ")\n",
    "\n",
    "p_value_z = 1 - stats.norm.cdf(z_stat)\n",
    "\n",
    "print(\"Large-sample z-test approximation\")\n",
    "print(\"z-statistic:\", z_stat)\n",
    "print(\"p-value:\", p_value_z)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "77b93b45",
   "metadata": {},
   "source": [
    "# Addional: Cohen's d "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 94,
   "id": "aa863df4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Cohen's d: 0.5278865640868069\n"
     ]
    }
   ],
   "source": [
    "# Cohen's d effect size\n",
    "n1 = len(point_diff_champ)\n",
    "n2 = len(point_diff_non_champ)\n",
    "\n",
    "s1 = point_diff_champ.std(ddof=1)\n",
    "s2 = point_diff_non_champ.std(ddof=1)\n",
    "\n",
    "pooled_sd = np.sqrt(\n",
    "    ((n1 - 1) * s1**2 + (n2 - 1) * s2**2) / (n1 + n2 - 2)\n",
    ")\n",
    "\n",
    "cohen_d = (point_diff_champ.mean() - point_diff_non_champ.mean()) / pooled_sd\n",
    "\n",
    "print(\"Cohen's d:\", cohen_d)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c8b2438f",
   "metadata": {},
   "source": [
    "# Additional： Mann-Whitney U test"
