  {
   "cell_type": "markdown",
   "id": "f8c01595",
   "metadata": {},
   "source": [
    "## F-test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 103,
   "id": "b3e1c302",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Champion variance: 2.5575209778516057\n",
      "Non-champion variance: 3.384057593386628\n",
      "F statistic: 1.3231788214810023\n",
      "df1: 128 df2: 42\n",
      "Two-sided p-value: 0.2981120677997393\n"
     ]
    }
   ],
   "source": [
    "std_var_champ = std_point_diff_champ.var(ddof=1)\n",
    "std_var_non_champ = std_point_diff_non_champ.var(ddof=1)\n",
    "\n",
    "if std_var_champ >= std_var_non_champ:\n",
    "    std_F = std_var_champ / std_var_non_champ\n",
    "    std_df1 = len(std_point_diff_champ) - 1\n",
    "    std_df2 = len(std_point_diff_non_champ) - 1\n",
    "else:\n",
    "    std_F = std_var_non_champ / std_var_champ\n",
    "    std_df1 = len(std_point_diff_non_champ) - 1\n",
    "    std_df2 = len(std_point_diff_champ) - 1\n",
    "\n",
    "std_p_one_tail = 1 - stats.f.cdf(std_F, std_df1, std_df2)\n",
    "std_p_two_tail = 2 * std_p_one_tail\n",
    "\n",
    "print(\"Champion variance:\", std_var_champ)\n",
    "print(\"Non-champion variance:\", std_var_non_champ)\n",
    "print(\"F statistic:\", std_F)\n",
    "print(\"df1:\", std_df1, \"df2:\", std_df2)\n",
    "print(\"Two-sided p-value:\", std_p_two_tail)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2d76be4a",
   "metadata": {},
   "source": [
    "## Welch t-test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 104,
   "id": "54acd3e2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Welch's t-test on standardized average point differential\n",
      "t-statistic: 2.925295520713059\n",
      "p-value: 0.0022248736281242376\n"
     ]
    }
   ],
   "source": [
    "std_welch_result = stats.ttest_ind(\n",
    "    std_point_diff_champ,\n",
    "    std_point_diff_non_champ,\n",
    "    equal_var=False,\n",
    "    alternative=\"greater\"\n",
    ")\n",
    "\n",
    "print(\"Welch's t-test on standardized average point differential\")\n",
    "print(\"t-statistic:\", std_welch_result.statistic)\n",
    "print(\"p-value:\", std_welch_result.pvalue)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4bc76836",
   "metadata": {},
   "source": [
    "## Pooled t-test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 105,
   "id": "f655e939",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Pooled t-test on standardized average point differential\n",
      "t-statistic: 2.727390561833287\n",
      "p-value: 0.0035269256263430614\n"
     ]
    }
   ],
   "source": [
    "std_pooled_result = stats.ttest_ind(\n",
    "    std_point_diff_champ,\n",
    "    std_point_diff_non_champ,\n",
    "    equal_var=True,\n",
    "    alternative=\"greater\"\n",
    ")\n",
    "\n",
    "print(\"Pooled t-test on standardized average point differential\")\n",
    "print(\"t-statistic:\", std_pooled_result.statistic)\n",
    "print(\"p-value:\", std_pooled_result.pvalue)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "666dca2e",
   "metadata": {},
   "source": [
    "## z-test "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 106,
   "id": "ff31a29b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Large-sample z-test approximation on standardized average point differential\n",
      "z-statistic: 2.925295520713059\n",
      "p-value: 0.0017206462582546322\n"
     ]
    }
   ],
   "source": [
    "std_mean_champ = std_point_diff_champ.mean()\n",
    "std_mean_non_champ = std_point_diff_non_champ.mean()\n",
    "\n",
    "std_s_champ = std_point_diff_champ.std(ddof=1)\n",
    "std_s_non_champ = std_point_diff_non_champ.std(ddof=1)\n",
    "\n",
    "std_n_champ = len(std_point_diff_champ)\n",
    "std_n_non_champ = len(std_point_diff_non_champ)\n",
    "\n",
    "std_z_stat = (std_mean_champ - std_mean_non_champ) / np.sqrt(\n",
    "    std_s_champ**2 / std_n_champ\n",
    "    + std_s_non_champ**2 / std_n_non_champ\n",
    ")\n",
    "\n",
    "std_p_value_z = 1 - stats.norm.cdf(std_z_stat)\n",
    "\n",
    "print(\"Large-sample z-test approximation on standardized average point differential\")\n",
    "print(\"z-statistic:\", std_z_stat)\n",
    "print(\"p-value:\", std_p_value_z)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a72adbca",
   "metadata": {},
   "source": [
    "## Cohen's d"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 107,
   "id": "9febfa94",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Cohen's d: 0.480266698414014\n"
     ]
    }
   ],
   "source": [
    "std_n1 = len(std_point_diff_champ)\n",
    "std_n2 = len(std_point_diff_non_champ)\n",
    "\n",
    "std_s1 = std_point_diff_champ.std(ddof=1)\n",
    "std_s2 = std_point_diff_non_champ.std(ddof=1)\n",
    "\n",
    "std_pooled_sd = np.sqrt(\n",
    "    ((std_n1 - 1) * std_s1**2 + (std_n2 - 1) * std_s2**2)\n",
    "    / (std_n1 + std_n2 - 2)\n",
    ")\n",
    "\n",
    "std_cohen_d = (\n",
    "    std_point_diff_champ.mean() - std_point_diff_non_champ.mean()\n",
    ") / std_pooled_sd\n",
    "\n",
    "print(\"Cohen's d:\", std_cohen_d)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "016e4219",
   "metadata": {},
   "source": [
    "## Mann–Whitney U test"
   ]
  },
  {
   "cell_type": "code",
