  {
   "cell_type": "markdown",
   "id": "bb976b22",
   "metadata": {},
   "source": [
    "## z-test (n > 40)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 117,
   "id": "cb73e3d7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Large-sample z-test approximation on season-normalized point differential\n",
      "z-statistic: 3.5556085148732306\n",
      "p-value: 0.00018855262735029132\n"
     ]
    }
   ],
   "source": [
    "season_norm_mean_champ = season_norm_champ.mean()\n",
    "season_norm_mean_non_champ = season_norm_non_champ.mean()\n",
    "\n",
    "season_norm_s_champ = season_norm_champ.std(ddof=1)\n",
    "season_norm_s_non_champ = season_norm_non_champ.std(ddof=1)\n",
    "\n",
    "season_norm_n_champ = len(season_norm_champ)\n",
    "season_norm_n_non_champ = len(season_norm_non_champ)\n",
    "\n",
    "season_norm_z_stat = (season_norm_mean_champ - season_norm_mean_non_champ) / np.sqrt(\n",
    "    season_norm_s_champ**2 / season_norm_n_champ\n",
    "    + season_norm_s_non_champ**2 / season_norm_n_non_champ\n",
    ")\n",
    "\n",
    "season_norm_p_value_z = 1 - stats.norm.cdf(season_norm_z_stat)\n",
    "\n",
    "print(\"Large-sample z-test approximation on season-normalized point differential\")\n",
    "print(\"z-statistic:\", season_norm_z_stat)\n",
    "print(\"p-value:\", season_norm_p_value_z)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5aaccf94",
   "metadata": {},
   "source": [
    "## Cohen's d"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 118,
   "id": "178edb29",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Cohen's d: 0.6140109814404455\n"
     ]
    }
   ],
   "source": [
    "season_norm_n1 = len(season_norm_champ)\n",
    "season_norm_n2 = len(season_norm_non_champ)\n",
    "\n",
    "season_norm_s1 = season_norm_champ.std(ddof=1)\n",
    "season_norm_s2 = season_norm_non_champ.std(ddof=1)\n",
    "\n",
    "season_norm_pooled_sd = np.sqrt(\n",
    "    ((season_norm_n1 - 1) * season_norm_s1**2 + (season_norm_n2 - 1) * season_norm_s2**2)\n",
    "    / (season_norm_n1 + season_norm_n2 - 2)\n",
    ")\n",
    "\n",
    "season_norm_cohen_d = (\n",
    "    season_norm_champ.mean() - season_norm_non_champ.mean()\n",
    ") / season_norm_pooled_sd\n",
    "\n",
    "print(\"Cohen's d:\", season_norm_cohen_d)"
   ]
  },
