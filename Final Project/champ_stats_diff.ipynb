    "    alternative=\"greater\"\n",
    ")\n",
    "\n",
    "print(\"Standardized APD Mann-Whitney U test\")\n",
    "print(\"U statistic:\", u_result_std.statistic)\n",
    "print(\"p-value:\", u_result_std.pvalue)"
   ]
  },
