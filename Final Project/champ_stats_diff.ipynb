  {
   "cell_type": "markdown",
   "id": "d3edeb2e",
   "metadata": {},
   "source": [
    "## F-test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 114,
   "id": "8edad50a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Champion variance: 0.6676030063098729\n",
      "Non-champion variance: 0.7214866987639124\n",
      "F statistic: 1.0807121776636053\n",
      "df1: 128 df2: 42\n",
      "Two-sided p-value: 0.7924859128628552\n"
     ]
    }
   ],
   "source": [
    "season_norm_var_champ = season_norm_champ.var(ddof=1)\n",
    "season_norm_var_non_champ = season_norm_non_champ.var(ddof=1)\n",
    "\n",
    "if season_norm_var_champ >= season_norm_var_non_champ:\n",
    "    season_norm_F = season_norm_var_champ / season_norm_var_non_champ\n",
    "    season_norm_df1 = len(season_norm_champ) - 1\n",
    "    season_norm_df2 = len(season_norm_non_champ) - 1\n",
    "else:\n",
    "    season_norm_F = season_norm_var_non_champ / season_norm_var_champ\n",
    "    season_norm_df1 = len(season_norm_non_champ) - 1\n",
    "    season_norm_df2 = len(season_norm_champ) - 1\n",
    "\n",
    "season_norm_p_one_tail = 1 - stats.f.cdf(season_norm_F, season_norm_df1, season_norm_df2)\n",
    "season_norm_p_two_tail = 2 * season_norm_p_one_tail\n",
    "\n",
    "print(\"Champion variance:\", season_norm_var_champ)\n",
    "print(\"Non-champion variance:\", season_norm_var_non_champ)\n",
    "print(\"F statistic:\", season_norm_F)\n",
    "print(\"df1:\", season_norm_df1, \"df2:\", season_norm_df2)\n",
    "print(\"Two-sided p-value:\", season_norm_p_two_tail)"
   ]
  },
