     ]
    }
   ],
   "source": [
    "u_result_raw = stats.mannwhitneyu(\n",
    "    point_diff_champ,\n",
    "    point_diff_non_champ,\n",
    "    alternative=\"greater\"\n",
    ")\n",
    "\n",
    "print(\"Raw APD Mann-Whitney U test\")\n",
    "print(\"U statistic:\", u_result_raw.statistic)\n",
    "print(\"p-value:\", u_result_raw.pvalue)"
   ]
